GOLPREDICTOR_USERNAME=
GOLPREDICTOR_PASSWORD=
GOLPREDICTOR_BASE_URL=https://www.golpredictor.com
GOLPREDICTOR_GROUPS=Mundial CoreX,Mundial FIFA 2026
GOLPREDICTOR_HEDGE_GROUPS=Mundial FIFA 2026
PMUNDIALERA_TIMEZONE=America/Bogota
PMUNDIALERA_SUBMISSION_WINDOW_MINUTES=35
PMUNDIALERA_DRY_RUN=true
PMUNDIALERA_ENABLE_WEB_RESEARCH=true
PMUNDIALERA_MAX_RESEARCH_QUERIES=14
PMUNDIALERA_MAX_RESULTS_PER_QUERY=5
PMUNDIALERA_ENABLE_PAGE_SCRAPE=true
PMUNDIALERA_MAX_PAGES_PER_QUERY=2
PMUNDIALERA_MAX_SCRAPED_CHARS=1800
PMUNDIALERA_PREDICTION_ENGINE=codex
PMUNDIALERA_CODEX_EXECUTABLE=npx
PMUNDIALERA_CODEX_ARGS=-y @openai/codex --search exec -
PMUNDIALERA_CODEX_MODEL=
PMUNDIALERA_CODEX_TIMEOUT_SECONDS=300
PMUNDIALERA_DATA_DIR=.pmundialera
